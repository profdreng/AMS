FROM node:20-slim

WORKDIR /app

# Temporarily copy package.json (and lock file if it exists)
COPY package.json ./

# Install dependencies
RUN npm install

# Copy the rest of the application
COPY . .

# Expose Vite's default port
EXPOSE 5173

# Run Vite in dev mode with host binder
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
